{
  "name": "ai-skill-library",
  "displayName": "AI Skill Library",
  "description": "%extension.description%",
  "version": "0.1.0",
  "icon": "src/media/icon.ico",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-skills-explorer",
          "title": "%viewsContainers.title%",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "ai-skills-explorer": [
        {
          "id": "aiSkillLibraryView",
          "name": "%views.explorer.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "aiSkillLibrary.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "aiSkillLibrary.addSkill",
        "title": "%command.addSkill%",
        "icon": "$(add)"
      },
      {
        "command": "aiSkillLibrary.editSkill",
        "title": "%command.editSkill%",
        "icon": "$(pencil)"
      },
      {
        "command": "aiSkillLibrary.deleteSkill",
        "title": "%command.deleteSkill%",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aiSkillLibrary.addSkill",
          "when": "view == aiSkillLibraryView",
          "group": "navigation"
        },
        {
          "command": "aiSkillLibrary.refresh",
          "when": "view == aiSkillLibraryView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "aiSkillLibrary.editSkill",
          "when": "view == aiSkillLibraryView && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "aiSkillLibrary.deleteSkill",
          "when": "view == aiSkillLibraryView && viewItem == skill",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.21.5",
    "eslint": "^8.57.0",
    "module-alias": "^2.3.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "i18next": "^26.0.4"
  },
  "_moduleAliases": {
    "@": "out"
  }
}
